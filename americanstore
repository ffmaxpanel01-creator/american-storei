<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>American Store | Premium Virtual Gift Cards 🇺🇸</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
    min-height: 100vh;
    color: #fff;
}
/* ===== HEADER ===== */
.header {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
}
.header .logo {
    font-size: 26px;
    font-weight: 800;
    background: linear-gradient(45deg, #f093fb, #f5576c, #4facfe);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-decoration: none;
    cursor: pointer;
}
.header nav { display: flex; gap: 5px; flex-wrap: wrap; }
.header nav button {
    color: #ddd;
    background: none;
    border: none;
    padding: 8px 16px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s;
}
.header nav button:hover { background: rgba(255,255,255,0.15); color: #fff; }
.header nav button.active { background: linear-gradient(45deg, #f093fb, #f5576c); color: #fff; }

/* ===== CONTAINER ===== */
.container { max-width: 1200px; margin: 0 auto; padding: 20px; }

/* ===== SECTIONS ===== */
.section { display: none; }
.section.active { display: block; }

/* ===== HERO ===== */
.hero {
    text-align: center;
    padding: 50px 20px 30px;
}
.hero h1 { font-size: 42px; font-weight: 800; margin-bottom: 8px; }
.hero h1 span { background: linear-gradient(45deg, #f093fb, #f5576c); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.hero p { font-size: 17px; color: #aaa; max-width: 600px; margin: 0 auto; }
.hero .badge {
    display: inline-block;
    background: rgba(76,175,80,0.2);
    border: 1px solid #4CAF50;
    color: #4CAF50;
    padding: 5px 16px;
    border-radius: 20px;
    font-size: 13px;
    margin-top: 12px;
}

/* ===== PRODUCTS GRID ===== */
.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    margin: 30px 0;
}
.product-card {
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 18px;
    padding: 25px 20px;
    text-align: center;
    transition: all 0.4s;
    cursor: pointer;
}
.product-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255,255,255,0.3);
    box-shadow: 0 15px 50px rgba(0,0,0,0.4);
    background: rgba(255,255,255,0.1);
}
.product-card .icon { font-size: 56px; margin-bottom: 12px; }
.product-card h3 { font-size: 17px; margin-bottom: 6px; }
.product-card .price-tag {
    display: inline-block;
    background: linear-gradient(45deg, #f093fb, #f5576c);
    padding: 5px 16px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 12px;
}
.product-card p { color: #888; font-size: 13px; margin-bottom: 12px; }

/* ===== GLASS CARD ===== */
.glass {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
}

/* ===== FORM CONTAINER ===== */
.form-container {
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 35px;
    max-width: 500px;
    margin: 20px auto;
}
.form-container h2 { text-align: center; margin-bottom: 20px; font-size: 22px; }
.form-group { margin-bottom: 16px; }
.form-group label { display: block; margin-bottom: 5px; color: #ccc; font-size: 13px; }
.form-group input, .form-group select {
    width: 100%;
    padding: 12px 14px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 11px;
    color: #fff;
    font-size: 14px;
    outline: none;
    transition: border 0.3s;
}
.form-group input:focus, .form-group select:focus { border-color: #4facfe; }
.form-group select option { background: #1a1a3e; color: #fff; }
.form-group input::placeholder { color: #777; }

/* ===== BUTTONS ===== */
.btn {
    padding: 12px 25px;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}
.btn-block { width: 100%; }
.btn-primary { background: linear-gradient(45deg, #f093fb, #f5576c); }
.btn-primary:hover { transform: scale(1.02); box-shadow: 0 6px 20px rgba(245,87,108,0.4); }
.btn-success { background: linear-gradient(45deg, #43e97b, #38f9d7); color: #000; }
.btn-danger { background: linear-gradient(45deg, #f5576c, #ff6f91); }
.btn-warning { background: linear-gradient(45deg, #f6d365, #fda085); color: #000; }
.btn-info { background: linear-gradient(45deg, #4facfe, #00f2fe); color: #000; }
.btn-sm { padding: 6px 14px; font-size: 12px; }

/* ===== PRICE OPTIONS ===== */
.price-options {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 12px 0;
}
.price-option {
    background: rgba(255,255,255,0.1);
    border: 2px solid rgba(255,255,255,0.15);
    padding: 8px 18px;
    border-radius: 11px;
    cursor: pointer;
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    transition: all 0.3s;
    min-width: 80px;
    text-align: center;
}
.price-option:hover { border-color: #f5576c; background: rgba(245,87,108,0.2); }
.price-option.selected { border-color: #f5576c; background: rgba(245,87,108,0.3); }

/* ===== PAYMENT PAGE ===== */
.payment-layout {
    display: flex;
    flex-wrap: wrap;
    gap: 25px;
    justify-content: center;
    margin: 25px 0;
}
.payment-qr-box {
    text-align: center;
    background: #fff;
    padding: 25px;
    border-radius: 18px;
    min-width: 320px;
}
.payment-qr-box img { max-width: 280px; height: auto; border-radius: 10px; }
.payment-qr-box .upi-id {
    color: #333;
    margin-top: 10px;
    font-weight: 700;
    font-size: 15px;
    background: #f0f0f0;
    padding: 6px 14px;
    border-radius: 8px;
    display: inline-block;
}
.payment-qr-box .big-amount {
    color: #f5576c;
    font-size: 32px;
    font-weight: 800;
    margin: 8px 0;
}
.payment-info {
    background: rgba(255,255,255,0.07);
    border-radius: 18px;
    padding: 25px;
    min-width: 300px;
    flex: 1;
}
.payment-info h3 { margin-bottom: 12px; }
.detail-row {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}
.detail-row .label { color: #aaa; font-size: 14px; }
.detail-row .value { font-weight: 600; font-size: 14px; }

/* ===== ALERTS ===== */
.alert {
    padding: 12px 18px;
    border-radius: 11px;
    margin: 12px 0;
    font-weight: 500;
    font-size: 14px;
}
.alert-success { background: rgba(76,175,80,0.2); border: 1px solid #4CAF50; color: #4CAF50; }
.alert-error { background: rgba(244,67,54,0.2); border: 1px solid #f44336; color: #f44336; }
.alert-info { background: rgba(33,150,243,0.2); border: 1px solid #2196F3; color: #2196F3; }
.alert-warning { background: rgba(255,152,0,0.2); border: 1px solid #FF9800; color: #FF9800; }

/* ===== TABLE ===== */
.table-wrap { overflow-x: auto; }
table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
}
table th {
    background: rgba(255,255,255,0.1);
    padding: 10px 12px;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
}
table td {
    padding: 10px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
}
table tr:hover { background: rgba(255,255,255,0.03); }

/* ===== BADGE ===== */
.badge {
    padding: 3px 10px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 600;
    display: inline-block;
}
.badge-pending { background: rgba(255,167,38,0.2); border: 1px solid #ffa726; color: #ffa726; }
.badge-approved { background: rgba(76,175,80,0.2); border: 1px solid #4CAF50; color: #4CAF50; }
.badge-rejected { background: rgba(244,67,54,0.2); border: 1px solid #f44336; color: #f44336; }

/* ===== ADMIN TABS ===== */
.admin-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
    flex-wrap: wrap;
}
.admin-tabs button {
    color: #ddd;
    background: rgba(255,255,255,0.05);
    border: none;
    padding: 9px 18px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s;
    font-weight: 500;
}
.admin-tabs button:hover, .admin-tabs button.active { background: rgba(255,255,255,0.15); color: #fff; }

/* ===== STATS ===== */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 14px;
    margin-bottom: 20px;
}
.stat-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 18px;
    text-align: center;
}
.stat-card .num { font-size: 28px; font-weight: 800; }
.stat-card .lbl { color: #aaa; font-size: 13px; margin-top: 3px; }

/* ===== CARD CODE DISPLAY ===== */
.card-code-box {
    background: linear-gradient(45deg, rgba(76,175,80,0.15), rgba(33,150,243,0.15));
    border: 2px solid rgba(76,175,80,0.3);
    border-radius: 16px;
    padding: 20px;
    text-align: center;
    margin-top: 15px;
}
.card-code-box .code {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: 3px;
    word-break: break-all;
    background: rgba(0,0,0,0.3);
    padding: 10px;
    border-radius: 10px;
    font-family: monospace;
}

/* ===== MODAL ===== */
.modal-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.7);
    align-items: center;
    justify-content: center;
    z-index: 1000;
}
.modal-overlay.show { display: flex; }
.modal-box {
    background: #1a1a3e;
    border-radius: 22px;
    padding: 35px;
    max-width: 480px;
    width: 92%;
    max-height: 90vh;
    overflow-y: auto;
}
.modal-box h2 { text-align: center; margin-bottom: 18px; }

/* ===== MISC ===== */
.text-center { text-align: center; }
.mt-10 { margin-top: 10px; }
.mt-15 { margin-top: 15px; }
.mt-20 { margin-top: 20px; }
.mb-15 { margin-bottom: 15px; }
.flex { display: flex; }
.gap-8 { gap: 8px; }
.gap-10 { gap: 10px; }
.wrap { flex-wrap: wrap; }
.justify-center { justify-content: center; }
.items-center { align-items: center; }
.hidden { display: none !important; }
footer {
    text-align: center;
    padding: 25px;
    color: #666;
    font-size: 13px;
}
</style>
</head>
<body>

<!-- ============================================================ -->
<!-- HEADER -->
<!-- ============================================================ -->
<div class="header">
    <div class="logo" onclick="showSection('home')">🇺🇸 American <span style="-webkit-text-fill-color:#aaa;">Store</span></div>
    <nav>
        <button onclick="showSection('home')" id="nav-home" class="active">🏪 Store</button>
        <button onclick="showSection('track')" id="nav-track">📦 Track</button>
        <button onclick="showSection('admin')" id="nav-admin">🔐 Admin</button>
    </nav>
</div>

<div class="container">

<!-- ============================================================ -->
<!-- SECTION: HOME (STORE) -->
<!-- ============================================================ -->
<div id="section-home" class="section active">
    <div class="hero">
        <h1>Welcome to <span>American Store</span> 🇺🇸</h1>
        <p>Premium virtual gift cards &amp; codes at the best prices. Pay securely via UPI. Instant delivery after admin approval.</p>
        <div class="badge">✅ All prices in ₹ INR • UPI Payment • Admin Approved</div>
    </div>

    <div class="products-grid" id="productGrid"></div>

    <!-- Order Modal -->
    <div id="orderModal" class="modal-overlay">
        <div class="modal-box">
            <div id="modalIcon" style="font-size:56px;text-align:center;margin-bottom:5px;"></div>
            <h2 id="modalTitle">Product Name</h2>
            <form id="orderForm" onsubmit="placeOrder(event)">
                <input type="hidden" name="productId" id="inputProductId">
                <input type="hidden" name="amount" id="inputAmount">

                <div class="form-group">
                    <label>Select Amount (₹)</label>
                    <div class="price-options" id="modalPrices"></div>
                </div>
                <div class="form-group">
                    <label>Your Full Name</label>
                    <input type="text" id="inputName" required placeholder="Enter your full name">
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" id="inputEmail" required placeholder="you@email.com">
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" id="inputPhone" required placeholder="+91 9876543210">
                </div>
                <button type="submit" class="btn btn-primary btn-block">Proceed to Payment →</button>
                <button type="button" class="btn btn-block" style="background:rgba(255,255,255,0.1);margin-top:6px;" onclick="closeModal('orderModal')">Cancel</button>
            </form>
        </div>
    </div>
</div>

<!-- ============================================================ -->
<!-- SECTION: PAYMENT (shown after order placement) -->
<!-- ============================================================ -->
<div id="section-payment" class="section">
    <div id="paymentContent"></div>
</div>

<!-- ============================================================ -->
<!-- SECTION: TRACK ORDER -->
<!-- ============================================================ -->
<div id="section-track" class="section">
    <div class="hero" style="padding:35px 20px;">
        <h1>📦 Track Your Order</h1>
        <p>Enter your Order ID to check status and get your virtual card code</p>
    </div>
    <div class="form-container" style="max-width:400px;">
        <form onsubmit="trackOrder(event)">
            <div class="form-group">
                <label>Order ID</label>
                <input type="number" id="trackOrderId" required placeholder="e.g. 1, 2, 3..." style="text-align:center;font-size:22px;">
            </div>
            <button type="submit" class="btn btn-primary btn-block">🔍 Check Status</button>
        </form>
        <div id="trackResult" class="mt-15"></div>
    </div>
</div>

<!-- ============================================================ -->
<!-- SECTION: ADMIN PANEL -->
<!-- ============================================================ -->
<div id="section-admin" class="section">
    <!-- Admin Login -->
    <div id="adminLogin">
        <div class="hero" style="padding:35px 20px;">
            <h1>🔐 Admin Panel</h1>
            <p>Secure login for store administrators</p>
        </div>
        <div class="form-container" style="max-width:380px;">
            <h2>Admin Login</h2>
            <div id="adminLoginError" class="hidden"></div>
            <form onsubmit="adminLogin(event)">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" id="adminUser" required placeholder="Admin username">
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="adminPass" required placeholder="Enter password">
                </div>
                <button type="submit" class="btn btn-primary btn-block">🔑 Login</button>
            </form>
            <p style="text-align:center;color:#666;font-size:12px;margin-top:12px;">Default: admin / Admin@123</p>
        </div>
    </div>

    <!-- Admin Dashboard -->
    <div id="adminDashboard" class="hidden">
        <div class="hero" style="padding:25px 20px;">
            <h1>⚙️ Admin Dashboard</h1>
            <p>Manage orders, approvals, and store settings</p>
        </div>
        <div id="adminMsg" class="hidden"></div>
        <div class="stats-grid" id="adminStats"></div>

        <div class="admin-tabs">
            <button onclick="adminTab('orders')" id="tab-orders" class="active">📋 Orders</button>
            <button onclick="adminTab('settings')" id="tab-settings">⚙️ Settings</button>
            <button onclick="adminTab('password')" id="tab-password">🔑 Password</button>
            <button onclick="adminLogout()" style="margin-left:auto;background:rgba(244,67,54,0.2);color:#ef5350;">🚪 Logout</button>
        </div>

        <!-- Tab: Orders -->
        <div id="adminTabOrders" class="admin-panel">
            <h3 style="margin-bottom:12px;">📋 All Orders</h3>
            <div class="table-wrap">
                <table>
                    <thead><tr>
                        <th>#</th><th>Customer</th><th>Product</th><th>Amount</th>
                        <th>Date</th><th>Status</th><th>Card Code</th><th>Action</th>
                    </tr></thead>
                    <tbody id="ordersTableBody"></tbody>
                </table>
            </div>
            <p id="noOrders" class="hidden" style="text-align:center;color:#666;padding:30px;">No orders yet.</p>
        </div>

        <!-- Tab: Settings -->
        <div id="adminTabSettings" class="admin-panel hidden">
            <h3 style="margin-bottom:15px;">⚙️ Store Settings</h3>
            <div class="glass" style="padding:25px;max-width:500px;">
                <form onsubmit="updateSettings(event)">
                    <div class="form-group">
                        <label>UPI ID (Payment Address)</label>
                        <input type="text" id="settingUpi" required>
                    </div>
                    <div class="form-group">
                        <label>Store Name</label>
                        <input type="text" id="settingStoreName" required>
                    </div>
                    <button type="submit" class="btn btn-primary">💾 Save Settings</button>
                </form>
            </div>
        </div>

        <!-- Tab: Password -->
        <div id="adminTabPassword" class="admin-panel hidden">
            <h3 style="margin-bottom:15px;">🔑 Change Admin Password</h3>
            <div style="max-width:400px;">
                <form onsubmit="changeAdminPassword(event)">
                    <div class="form-group">
                        <label>Current Password</label>
                        <input type="password" id="oldPass" required>
                    </div>
                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" id="newPass" required minlength="6">
                    </div>
                    <button type="submit" class="btn btn-primary">🔄 Update Password</button>
                </form>
            </div>
        </div>
    </div>
</div>

</div><!-- /container -->

<footer>
    <p>🇺🇸 American Store — Premium Virtual Gift Cards • All prices in ₹ INR • UPI Payments</p>
    <p style="font-size:12px;margin-top:4px;">&copy; 2026 American Store. All rights reserved.</p>
</footer>

