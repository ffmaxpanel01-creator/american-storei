<!-- JAVASCRIPT - ALL LOGIC -->
<!-- ============================================================ -->
<script>
// ===== DATA STORE (LocalStorage based DB) =====
const DB = {
    get(key, def) {
        try { return JSON.parse(localStorage.getItem('amstore_' + key)) ?? def; }
        catch { return def; }
    },
    set(key, val) { localStorage.setItem('amstore_' + key, JSON.stringify(val)); },
  
